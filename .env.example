# ── Server ──────────────────────────────────────────────
PORT=3000

# ── Admin ───────────────────────────────────────────────
# Change this to a strong password before deploying
ADMIN_PASSWORD=change-me-before-deploy

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-random-secret

# ── Square Payments ─────────────────────────────────────
# Get these from https://developer.squareup.com → Your Application
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=sandbox-sq0idb-XXXXXX
SQUARE_LOCATION_ID=XXXXXXXXXXXXXXXX
SQUARE_ACCESS_TOKEN=EAAAl_XXXXXXXXXXXXXXXX

# ── Data Storage ────────────────────────────────────────
# On Railway: attach a Volume mounted at /data and set DATA_DIR=/data
DATA_DIR=./data
